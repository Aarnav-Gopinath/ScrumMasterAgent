# Copy this file to .env and fill in your real values. Never commit .env.

# GitHub personal access token (or the GITHUB_TOKEN provided automatically in Actions).
# Needs repo scope so the agent can read issues and post comments.
GITHUB_TOKEN=ghp_your_token_here

# Anthropic Claude API key, used only by the Standup Reporter to generate the digest.
ANTHROPIC_API_KEY=sk-ant-your_key_here
